# GoalOS SaaS platform
DATABASE_URL=postgresql://goalos:goalos@localhost:5432/goalos
JWT_SECRET=change-me-in-production-use-32-chars-min
REDIS_URL=redis://localhost:6379

# API Gateway (public entry)
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# Internal service URLs (gateway only)
AUTH_SERVICE_URL=http://127.0.0.1:4001
GOALS_SERVICE_URL=http://127.0.0.1:4002
USAGE_SERVICE_URL=http://127.0.0.1:4003
COACH_SERVICE_URL=http://127.0.0.1:4004
INSIGHTS_SERVICE_URL=http://127.0.0.1:4005

# CORS (comma-separated origins in production)
CORS_ORIGIN=http://localhost:3000

# Rate limiting at gateway
RATE_LIMIT_MAX=200
